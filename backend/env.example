# Application
PROJECT_NAME="小说RAG分析系统"
VERSION="1.0.0"
DEBUG=false

# Database
DATABASE_URL="sqlite+aiosqlite:///./novel_rag.db"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Qdrant
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_COLLECTION="novel_embeddings"

# Zhipu AI API (获取一个即可)
ZAI_API_KEY="your-zhipu-api-key-here"
# 或者使用
# ZHIPU_API_KEY="your-zhipu-api-key-here"

# Text Processing
MAX_UPLOAD_SIZE_MB=50
MIN_WORD_COUNT=1000
MIN_CHINESE_RATIO=0.6
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_TOP_K=8

# CORS Origins (逗号分隔，不要加引号和空格)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

