# Application
PROJECT_NAME="小说RAG分析系统"
VERSION="1.0.0"
DEBUG=false

# Database
DATABASE_URL="sqlite+aiosqlite:///./novel_rag.db"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Qdrant
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_COLLECTION="novel_embeddings"

# Zhipu AI API (获取一个即可)
ZAI_API_KEY="your-zhipu-api-key-here"
# 或者使用
# ZHIPU_API_KEY="your-zhipu-api-key-here"

# Text Processing (已优化的默认值)
MAX_UPLOAD_SIZE_MB=50
MIN_WORD_COUNT=1000
MIN_CHINESE_RATIO=0.6
CHUNK_SIZE=1200  # 优化: 让每个chunk更聚焦
CHUNK_OVERLAP=200  # 优化: 约17%重叠率避免信息断裂
MAX_TOP_K=15  # 优化: 获取更多候选
MIN_RELEVANCE_SCORE=0.65  # 最低相似度阈值（过滤低相关度结果）
EMBEDDING_BATCH_SIZE=64  # 批量处理大小
EMBEDDING_DIMENSION=1024  # 向量维度 (256/512/1024/2048)

# RAG搜索优化配置
ENABLE_HYDE=true  # 是否启用HyDE假设文档嵌入（提升召回率，推荐启用）
HYDE_MODEL=glm-4-flash  # HyDE使用的模型（glm-4-flash更稳定快速，glm-4-plus质量更高但可能不稳定）
ENABLE_QUERY_REWRITE=false  # 是否启用查询改写（与HyDE二选一，建议用HyDE）
ENABLE_RERANKING=false  # 是否启用重排序（消耗更多token，但提升准确性）
ENABLE_HYBRID_SEARCH=false  # 是否启用混合检索（实验性功能，暂未实现）
CONTEXT_EXPAND_WINDOW=1  # 上下文扩展窗口（前后各扩展N个chunk，0表示不扩展）

# CORS Origins (逗号分隔，不要加引号和空格)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

